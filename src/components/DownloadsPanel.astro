<aside id="downloads-panel" class="status-panel" hidden>
  <div class="panel-head">
    <p class="panel-title">Loading models</p>
    <span id="downloads-summary" class="panel-summary"></span>
  </div>
  <div class="panel-progress">
    <div id="downloads-overall" class="panel-progress-fill"></div>
  </div>
  <ul id="downloads-list"></ul>
  <div class="panel-foot">
    <button id="clear-models-btn" class="clear-models-btn" type="button" disabled>
      Delete downloaded models
    </button>
    <p id="clear-models-note" class="clear-models-note" hidden></p>
  </div>
</aside>
