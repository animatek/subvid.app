---
import Check from "../assets/svg/check.svg"
---

<div id="status-dock" class="status-dock">
  <span id="downloads-label" class="status-label"></span>
  <button
    id="downloads-toggle"
    class="status-btn"
    aria-label="Estado de los modelos"
    type="button"
  >
    <svg class="ring" viewBox="0 0 38 38" aria-hidden="true">
      <circle class="ring-bg" cx="19" cy="19" r="15.5"></circle>
      <circle id="downloads-ring" class="ring-fg" cx="19" cy="19" r="15.5"
      ></circle>
    </svg>
    <span id="downloads-pct" class="ring-pct">0%</span>
    <Check class="ring-check" />
  </button>
</div>
