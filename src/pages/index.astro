---
import Layout from "../layouts/Layout.astro"
import StatusDock from "../components/StatusDock.astro"
import DownloadsPanel from "../components/DownloadsPanel.astro"
import UploadStage from "../components/UploadStage.astro"
import ConfigStage from "../components/ConfigStage.astro"
import EditorStage from "../components/EditorStage.astro"
import ExportModal from "../components/ExportModal.astro"
import "../styles/app.css"
---

<Layout
  title="SubThis Now — Subtítulos para cualquier vídeo"
  description="Genera y edita subtítulos con IA directamente en tu navegador. Sin subidas, sin servidores."
>
  <StatusDock />
  <DownloadsPanel />

  <main class="app" id="app">
    <UploadStage />
    <ConfigStage />
    <EditorStage />
  </main>

  <ExportModal />

  <script>
    import "../scripts/app.ts"
  </script>
</Layout>
