---
import DropzoneIcon from "../assets/svg/dropzone.svg"
---

<section id="stage-upload" class="stage-upload">
  <div class="hero">
    <h1>
      Subtítulos para
      <span class="hero-mark">cualquier&nbsp;vídeo</span>
    </h1>
    <p class="hero-sub">
      Genera, edita y traduce subtítulos con IA. Sin subir nada a ningún
      servidor.
    </p>
  </div>

  <div
    id="dropzone"
    class="dropzone"
    role="button"
    tabindex="0"
    aria-label="Selecciona o suelta un vídeo"
  >
    <input id="video-input" type="file" accept="video/*" hidden />
    <div class="dz-body">
      <DropzoneIcon class="dz-icon" />
      <strong class="dz-label">Suelta tu vídeo</strong>
      <span class="dz-hint"
        >o haz clic para explorar &nbsp;&middot;&nbsp; MP4, MOV, WebM, MKV</span
      >
    </div>
  </div>
</section>
