---
import Close from "../assets/svg/close.svg"
---

<div id="export-modal" class="export-modal" hidden>
  <div class="export-backdrop" id="export-backdrop"></div>
  <div
    class="export-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="export-title"
  >
    <div class="export-head">
      <h2 id="export-title" class="export-title">Exportando vídeo</h2>
      <button
        id="export-close"
        class="export-close"
        type="button"
        aria-label="Cerrar"
        hidden
      >
        <Close />
      </button>
    </div>

    <p id="export-stage" class="export-stage">Preparando…</p>

    <div class="export-track">
      <div id="export-fill" class="export-fill"></div>
    </div>
    <div class="export-foot">
      <span id="export-pct" class="export-pct">0%</span>
      <span id="export-hint" class="export-hint"
        >El vídeo se reproducirá una vez para grabar los subtítulos.</span
      >
    </div>

    <ul id="export-steps" class="export-steps"></ul>

    <p id="export-error" class="export-error" hidden></p>
  </div>
</div>
