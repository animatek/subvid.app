---
import ChevronLeft from "@/assets/svg/chevron-left.svg"
import Download from "@/assets/svg/download.svg"
import Upload from "@/assets/svg/upload.svg"
import Undo from "@/assets/svg/undo.svg"
import Redo from "@/assets/svg/redo.svg"
import SubtitleStyleBar from "@/components/SubtitleStyleBar.astro"
import EditorSidebar from "@/components/EditorSidebar.astro"
import Timeline from "@/components/Timeline.astro"
import { useTranslations } from "@/i18n/ui"

const t = useTranslations(Astro.currentLocale)
---

<section id="stage-editor" class="stage-editor" hidden>
  <header class="editor-top">
    <button id="back-btn" class="btn-ghost" type="button">
      <ChevronLeft />
      {t.editor.back}
    </button>
    <div class="editor-history">
      <button
        id="undo-btn"
        class="btn-icon"
        type="button"
        aria-label={t.editor.undo}
        title={t.editor.undoTitle}
        disabled
      >
        <Undo />
      </button>
      <button
        id="redo-btn"
        class="btn-icon"
        type="button"
        aria-label={t.editor.redo}
        title={t.editor.redoTitle}
        disabled
      >
        <Redo />
      </button>
    </div>
    <div id="video-meta" class="video-meta"></div>
    <span id="generation-time" class="generation-time" hidden></span>
    <div class="editor-actions">
      <button id="import-srt-btn" class="btn-soft" type="button" disabled>
        <Upload />
        {t.editor.importSrt}
      </button>
      <input id="import-srt-input" type="file" accept=".srt,text/plain" hidden />
      <button id="download-srt-btn" class="btn-soft" type="button" disabled>
        <Download />
        {t.editor.downloadSrt}
      </button>
      <div class="export-options" aria-label={t.editor.videoExportOptions}>
        <label class="export-field" for="export-format">
          <span>{t.editor.videoFormat}</span>
          <select id="export-format" name="export-format">
            <option value="mp4">{t.editor.formatMp4}</option>
            <option value="webm">{t.editor.formatWebm}</option>
          </select>
        </label>
        <label class="export-field" for="export-quality">
          <span>{t.editor.videoQuality}</span>
          <select id="export-quality" name="export-quality">
            <option value="optimized">{t.editor.qualityOptimized}</option>
            <option value="high">{t.editor.qualityHigh}</option>
            <option value="lossless">{t.editor.qualityLossless}</option>
          </select>
        </label>
        <label class="export-field" for="export-layout">
          <span>{t.editor.videoLayout}</span>
          <select id="export-layout" name="export-layout">
            <option value="original">{t.editor.layoutOriginal}</option>
            <option value="vertical-stream">{t.editor.layoutVerticalStream}</option>
          </select>
        </label>
        <button id="camera-crop-btn" class="btn-soft btn-soft--crop" type="button">
          {t.editor.defineCamera}
        </button>
        <button id="screen-crop-btn" class="btn-soft btn-soft--crop" type="button">
          {t.editor.defineScreen}
        </button>
        <button id="vertical-preview-btn" class="btn-soft btn-soft--crop" type="button">
          {t.editor.verticalPreview}
        </button>
      </div>
      <button
        id="download-video-btn"
        class="btn-soft btn-soft--primary"
        type="button"
        disabled
      >
        <Download />
        {t.editor.downloadVideo}
      </button>
    </div>
  </header>

  <div class="editor-body">
    <!-- Main column -->
    <div class="editor-main">
      <div class="video-preview" id="video-preview">
        <video id="video" playsinline></video>
        <div id="camera-crop-overlay" class="camera-crop-overlay" hidden>
          <div id="camera-crop-box" class="camera-crop-box" tabindex="0">
            <span class="camera-crop-label">{t.editor.cameraCrop}</span>
            <span class="camera-crop-handle" aria-hidden="true"></span>
          </div>
          <button id="camera-crop-set-btn" class="camera-crop-set" type="button">
            {t.editor.setCrop}
          </button>
        </div>
        <div id="vertical-preview-panel" class="vertical-preview-panel" hidden>
          <div class="vertical-preview-head">
            <span>{t.editor.verticalPreview}</span>
            <button id="vertical-preview-close" type="button">{t.export.close}</button>
          </div>
          <canvas id="vertical-preview-canvas" width="270" height="480"></canvas>
        </div>
        <div id="caption-guides" class="caption-guides" hidden aria-hidden="true">
          <span class="caption-guide caption-guide-v"></span>
          <span class="caption-guide caption-guide-h caption-guide-h--top"></span>
          <span class="caption-guide caption-guide-h caption-guide-h--middle"
          ></span>
          <span class="caption-guide caption-guide-h caption-guide-h--bottom"
          ></span>
        </div>
        <div
          id="caption-overlay"
          class="caption-layer"
          data-drag-label={t.style.dragAria}
        >
        </div>
      </div>

      <SubtitleStyleBar />
    </div>

    <EditorSidebar />
  </div>

  <Timeline />
</section>
