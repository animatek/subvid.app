---
import Check from "../assets/svg/check.svg"
import Ring from "../assets/svg/ring.svg"
---

<div id="status-dock" class="status-dock">
  <span id="downloads-label" class="status-label"></span>
  <button
    id="downloads-toggle"
    class="status-btn"
    aria-label="Models status"
    type="button"
  >
    <Ring class="ring" />
    <span id="downloads-pct" class="ring-pct">0%</span>
    <Check class="ring-check" />
  </button>
</div>
