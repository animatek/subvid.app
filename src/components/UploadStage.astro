---
import DropzoneIcon from "../assets/svg/dropzone.svg"
---

<section id="stage-upload" class="stage-upload">
  <div class="hero">
    <h1>
      Subtitles for
      <span class="hero-mark">any&nbsp;video</span>
    </h1>
    <p class="hero-sub">
      Generate, edit and translate subtitles with AI. Without uploading
      anything to any server.
    </p>
  </div>

  <div
    id="dropzone"
    class="dropzone"
    role="button"
    tabindex="0"
    aria-label="Select or drop a video"
  >
    <input id="video-input" type="file" accept="video/*" hidden />
    <div class="dz-body">
      <DropzoneIcon class="dz-icon" />
      <strong class="dz-label">Drop your video</strong>
      <span class="dz-hint"
        >or click to browse &nbsp;&middot;&nbsp; MP4, MOV, WebM, MKV</span
      >
    </div>
  </div>
</section>
