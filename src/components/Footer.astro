---
import HeartIcon from "../assets/svg/heart.svg"
import GitHubIcon from "../assets/svg/github.svg"
import DollarIcon from "../assets/svg/dollar.svg"
---

<footer class="upload-footer">
  <span class="footer-credit">
    Developed by
    <a
      class="footer-link"
      href="https://midu.dev"
      target="_blank"
      rel="noopener noreferrer">midudev</a
    >
    with <HeartIcon class="footer-heart" />
  </span>
  <a
    class="footer-repo"
    href="https://github.com/midudev/subvid.app"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="View repository on GitHub"
  >
    <GitHubIcon class="footer-github" /> Code
  </a>
  <a
    class="footer-sponsor"
    href="https://github.com/sponsors/midudev"
    target="_blank"
    rel="noopener noreferrer"
  >
    <DollarIcon class="footer-sponsor-icon" /> Sponsor
  </a>
</footer>
